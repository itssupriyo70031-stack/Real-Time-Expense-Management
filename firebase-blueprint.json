{
  "entities": {
    "center": {
      "title": "Center",
      "description": "Financial unit or center representing a department or location.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "budget": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "budget"]
    },
    "expense": {
      "title": "Expense",
      "description": "A single financial transaction record.",
      "type": "object",
      "properties": {
        "merchant": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Declined", "Reimbursed"] },
        "description": { "type": "string" },
        "centerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["merchant", "amount", "category", "date", "status", "centerId"]
    },
    "profile": {
      "title": "User Profile",
      "description": "User specific settings and metadata.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" },
        "activeCenterId": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] }
      }
    },
    "budgetHistory": {
      "title": "Budget History",
      "description": "Log of budget changes for a center.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "date", "updatedAt"]
    }
  },
  "firestore": {
    "/shared_ledger/global_instance/centers/{centerId}": {
      "schema": "center",
      "description": "Financial centers in the shared ledger."
    },
    "/shared_ledger/global_instance/centers/{centerId}/history/{historyId}": {
      "schema": "budgetHistory",
      "description": "History of budget allocations."
    },
    "/shared_ledger/global_instance/expenses/{expenseId}": {
      "schema": "expense",
      "description": "Expenses in the shared ledger."
    },
    "/shared_ledger/global_instance/profile/settings": {
      "schema": "profile",
      "description": "Global application settings."
    }
  }
}
